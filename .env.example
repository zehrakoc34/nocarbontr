# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Supabase proje sayfası → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Güçlü rastgele bir string (en az 32 karakter)
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Storage (Supabase Storage) ────────────────────────────────────────────────
# Supabase proje sayfası → Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── AI / LLM (OpenAI) ─────────────────────────────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
